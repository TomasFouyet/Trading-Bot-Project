+            direction=direction,
+            bar_idx=len(df) - 1,
+            last_pivot_low=last_pivot_low,
+            last_pivot_high=last_pivot_high,
+            atr=atr,
+            stop_mode=stop_mode,
+            atr_sl_mult=self._atr_sl_mult,
+            buffer_atr=self._structural_buffer_atr,
