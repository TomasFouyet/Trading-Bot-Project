# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─────────────────────────────────────────
# Redis / Celery
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─────────────────────────────────────────
# Data storage
# ─────────────────────────────────────────
PARQUET_DIR=./data/parquet

# ─────────────────────────────────────────
# Trading bot defaults
# ─────────────────────────────────────────
# paper | real | backtest
BOT_MODE=paper
DEFAULT_SYMBOL=BTC-USDT
DEFAULT_TIMEFRAME=5m
# 0 = disabled leverage
LEVERAGE=1

# ─────────────────────────────────────────
# Risk manager
# ─────────────────────────────────────────
RISK_MAX_DAILY_DRAWDOWN_PCT=2.0
RISK_MAX_POSITION_PCT=5.0
RISK_MAX_TRADE_RISK_PCT=1.0
RISK_MAX_CONSECUTIVE_API_ERRORS=5
RISK_DATA_DELAY_THRESHOLD_S=60

# ─────────────────────────────────────────
# Costs / slippage
# ─────────────────────────────────────────
COMMISSION_BPS=7.5
SLIPPAGE_BPS=5.0

# ─────────────────────────────────────────
# Observability
# ─────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
PROMETHEUS_PORT=8001
ENVIRONMENT=development
